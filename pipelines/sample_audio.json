          "text_source": "assets/text/banter-example.txt",
          "output": "output/audio/banter-example.wav"
        },
        {
          "command": "generate_speech",
          "text_source": "assets/text/triples-concept.txt",
          "output": "output/audio/triples-concept.wav"
        },
        {
          "command": "generate_speech",
          "text_source": "assets/text/triples-example.txt",
          "output": "output/audio/triples-example.wav"
        },
        {
          "command": "generate_speech",
          "text_source": "assets/text/quotes-concept.txt",
