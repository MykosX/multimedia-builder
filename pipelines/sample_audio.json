          "text_source": "assets/text/one-liners-example.txt",
          "output": "output/audio/one-liners-example.wav"
        },
        {
          "command": "generate_speech",
          "text_source": "assets/text/banter-concept.txt",
          "output": "output/audio/banter-concept.wav"
        },
        {
