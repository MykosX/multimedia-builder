{
  "subproject-title": "Work on audio activities",
  "activities": [
    {
      "name"    : "Check tts models and speakers",
      "type"    : "audio",
      "actions" : [
        {
          "command"                 : "show-models",
          "enabled"                 : true
        },
        {
          "command"                 : "show-speakers",
          "enabled"                 : true
        }
      ]
    },
    {
      "name"    : "Tell a joke with tts",
      "type"    : "audio",
      "defaults": {
        "model-path"   : "tts_models/en/ljspeech/vits"
      },
      "actions" : [
        {
          "command"                 : "text-to-speech",
          "enabled"                 : true,
          "audio-name"              : "joke-start",
          "input-text-path"         : "assets/text/joke-start.txt",
          "output-audio-path"       : "output/audio/joke-start.wav"
        },
        {
          "command"                 : "text-to-speech",
          "enabled"                 : true,
          "audio-name"              : "joke-stop",
          "input-text-path"         : "assets/text/joke-stop.txt",
          "output-audio-path"       : "output/audio/joke-stop.wav"
        },
        {
          "command"                 : "create-silence",
          "enabled"                 : true,
          "audio-name"              : "joke-silence",
          "duration"                : 2.0,
          "output-audio-path"       : "output/audio/joke-silence.wav"
        },
        {
          "command"                 : "combine-audios",
          "enabled"                 : true,
          "audio-name"              : "joke-full",
          "input-audio-paths"       : ["output/audio/joke-start.wav", "output/audio/joke-silence.wav"],
          "audio-names"             : ["joke-stop"],
          "output-audio-path"       : "output/audio/joke-full.wav"
        },
        {
          "command"                 : "split-audio",
          "enabled"                 : true,
          "input-audio-path"        : "output/audio/joke-full.wav",
          "split-times"             : [1.00, 2.50],
          "output-audio-path"       : "output/audio/joke-split.wav"
        },
        {
          "command"                 : "audio-to-text",
          "enabled"                 : true,
          "audio-name"              : "joke-full",
          "output-text-path"        : "output/text/joke-transcript.srt"
        }
      ]
    }
  ]
}
